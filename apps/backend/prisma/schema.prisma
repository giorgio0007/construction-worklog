generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model WorkType {
  id       String    @id @default(uuid())
  name     String    @unique

  workLogs WorkLog[]
}

model WorkLog {
  id         String   @id @default(uuid())

  date       DateTime

  volume     Decimal

  unit       String

  workerName String

  comment    String?

  workTypeId String
  workType   WorkType @relation(fields: [workTypeId], references: [id])

  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}